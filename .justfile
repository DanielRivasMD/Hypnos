####################################################################################################

_default:
  @just --choose

####################################################################################################

@abort:

####################################################################################################

@list:
  just --list

####################################################################################################

# print justfile
[group('just')]
@show:
  bat .justfile --language make

####################################################################################################

# edit justfile
[group('just')]
@edit:
  micro .justfile

####################################################################################################

# compile roadmap action items
[group('dev')]
@todor:
  if [ "$(uname)" = "Darwin" ]; then \
    sed -i '' '/^==================================================$$/,/^==================================================$$/d' ROADMAP.txt; \
  else \
    sed -i '/^==================================================[[:space:]]*$/,/^==================================================[[:space:]]*$/d' ROADMAP.txt; \
  fi
  { printf '==================================================\n'; todor -s; printf '==================================================\n'; } >> ROADMAP.txt

####################################################################################################
# config
####################################################################################################

dir := '.hypnos'
config := dir / 'config'
app := 'Hypnos'
exe := 'hypnos'

####################################################################################################
# jobs
####################################################################################################

# build exec
[group('dev')]
build app=app:
  @echo "\n\033[1;33mBuilding\033[0;37m...\n=================================================="
  go build -v -o excalibur/{{app}}

####################################################################################################

# install locally
[group('dev')]
install app=app exe=exe:
  @echo "\n\033[1;33mInstalling\033[0;37m...\n=================================================="
  go install
  mv -v "${HOME}/go/bin/{{app}}" "${HOME}/go/bin/{{exe}}"
  @echo "\n\033[1;33mCopying\033[0;37m...\n=================================================="
  @if [ ! -d "${HOME}/{{dir}}" ]; then mkdir "${HOME}/{{dir}}"; fi
  @if test -e "${HOME}/{{config}}"; then rm -r "${HOME}/{{config}}"; fi && echo "\033[1;33mconfig\033[0;37m" && cp -v -R "config" "${HOME}/{{config}}"

####################################################################################################

# watch
[group('dev')]
watch:
  watchexec --clear --watch cmd -- 'just install'

####################################################################################################
